# 3dEZ Backend Environment Variables
# Copy to .env and fill in real values

# Anthropic API key (required for conversation engine)
ANTHROPIC_API_KEY=sk-ant-XXXX

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# SQLite database URL (async driver)
DATABASE_URL=sqlite+aiosqlite:///./3dez.db

# Secret for session token generation (change in production!)
SESSION_SECRET=change-me-in-production
